{
  "package_name": "file-drop-installer",
  "package_version": "1.3.0",
  "created_at": "2026-03-10",
  "purpose": "Install DropBridge backend and integrate native iOS uploader with existing Chrome extension receiver.",
  "components": {
    "supabase": {
      "schema": "supabase/schema/install.sql",
      "v2_migration": "supabase/schema/dropbridge_v2_account_link.sql",
      "rollback": "supabase/schema/rollback.sql",
      "functions": [
        "register-device",
        "upload-file",
        "list-pending",
        "update-upload-status",
        "register-device-v2",
        "upload-file-v2",
        "list-pending-v2",
        "update-upload-status-v2",
        "get-upload-status-v2",
        "wake-lectra-v2",
        "cleanup-expired-uploads"
      ],
      "function_source_root": "supabase/functions"
    },
    "ios": {
      "setup_doc": "ios/IOS_SETUP.md",
      "client_source": "ios/DropBridgeClient.swift",
      "pairing_parser": "ios/PairingLink.swift"
    },
    "extension": {
      "setup_doc": "extension/EXTENSION_SETUP.md",
      "status_mapping": "docs/STATUS_MODEL.md"
    }
  },
  "required_env": [
    "SUPABASE_PROJECT_REF",
    "SUPABASE_URL",
    "SUPABASE_PUBLISHABLE_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "APNS_KEY_ID",
    "APNS_TEAM_ID",
    "APNS_TOPIC",
    "APNS_PRIVATE_KEY_P8"
  ],
  "security_assumptions": [
    "Client apps only use publishable/anon key",
    "Edge Functions enforce device authentication",
    "Storage bucket is private",
    "RLS is enabled on public tables with deny-by-default",
    "Realtime/APNs wake paths are hints only; canonical state lives in tables and storage"
  ],
  "entrypoints": {
    "human_readme": "README.md",
    "agent_handoff": "AGENT_HANDOFF.md",
    "api_contract": "contracts/openapi.yaml"
  }
}
